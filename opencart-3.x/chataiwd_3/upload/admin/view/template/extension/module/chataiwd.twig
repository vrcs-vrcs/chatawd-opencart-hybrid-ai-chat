{{ header }}{{ column_left }}

<div id="content">
    <div class="page-header">
        <div class="container-fluid">
            <div class="float-end pull-right">
                <button type="button" onclick="saveFormBeforeRegistration(null, true)" data-toggle="tooltip" data-bs-toggle="tooltip" title="{{ button_save }}" class="btn btn-primary"><i class="fa fas fa-solid fa-save"></i></button>
                <a href="{{ back }}" data-toggle="tooltip" data-bs-toggle="tooltip" title="{{ button_back }}" class="btn btn-light"><i class="fa fas fa-solid fa-reply"></i></a>
            </div>
            <h1>{{ heading_title }}</h1>
            <ol class="breadcrumb">
                {% for breadcrumb in breadcrumbs %}
                    <li class="breadcrumb-item"><a href="{{ breadcrumb.href }}">{{ breadcrumb.text }}</a></li>
                {% endfor %}
            </ol>
        </div>
    </div>

    <div class="container-fluid">
        {% if error_warning %}
            <div class="alert alert-danger alert-dismissible">
                <i class="fa-solid fa-circle-exclamation"></i> {{ error_warning }}
                <button type="button" class="close btn-close" data-dismiss="alert" data-bs-dismiss="alert" style="float: right; background: none; border: none; font-size: 20px; line-height: 1;">&times;</button>
            </div>
        {% endif %}
        {% if success %}
            <div class="alert alert-success alert-dismissible">
                <i class="fa-solid fa-check-circle"></i> {{ success }}
                <button type="button" class="close btn-close" data-dismiss="alert" data-bs-dismiss="alert" style="float: right; background: none; border: none; font-size: 20px; line-height: 1;">&times;</button>
            </div>
        {% endif %}



        <div class="card panel panel-default" id="ai-chataiwd">
            <div class="card-header panel-heading"><i class="fa fas fa fa-pencil"></i> {{ text_edit }}</div>
            <div class="card-body panel-body">

                {% if module_chataiwd_registration_id and human and domain %}
                    <form action="{{ human }}" id="human-ai" method="post" target="_blank">
                        <input type="hidden" name="registration_id" value="{{ module_chataiwd_registration_id }}">
                        <input type="hidden" name="domain" value="{{ domain }}">
                        <input type="hidden" name="coupons" value='{{ coupons_json }}'>
                        <input type="hidden" name="language_code" value="{{ config_language }}">
                        <input type="hidden" name="vrcs_version" value="{{ vrcs_version }}">
                        <input type="hidden" name="rewards" id="vrcs-reward-presets" value="{{ module_chataiwd_rewards }}">
                        <input type="hidden" name="dispatcher_id" value="{{ dispatcher_id }}">
                        <input type="hidden" name="dispatcher_name" value="{{ dispatcher_name }}">

                        <div class="row mb-3 form-group" style="margin: 41px 0px">
                            <label class="col-sm-2 control-label">
                                {{ entry_dispatcher }}
                                <i class="fa fas fa-info-circle ms-1" data-toggle="tooltip" data-bs-toggle="tooltip" title="{{ help_dispatcher }}"></i>
                            </label>
                            <div class="col-sm-10">
                                <button type="button" class="btn btn-dispatcher mt-2" id="dispatcher-button">
                                    <i class="fa fas fa-solid fa-user-plus"></i> {{ button_dispatcher }}
                                </button>
                            </div>
                        </div>
                    </form>
                {% endif %}

                <form action="{{ save }}" id="form-ai" method="post" data-oc-toggle="ajax" class="form-horizontal">

                    <div id="vrcs-sync-container" style="display: none; margin-top: 20px;">
                        <fieldset>
                            <legend><i class="fas fa-brain" style="color: #00a8c6;"></i> {{ text_ai_learning|default('Az AI asszisztens felkészítése...') }}</legend>

                            <div class="row mb-3 form-group">
                                <div class="col-sm-12">
                                    <p style="font-size: 13px; color: #555;">
                                        {{ text_ai_learning_help|default('Kérjük, ne zárd be az ablakot. <br>Az AI épp elemzi és indexeli a webáruház kínálatát, hogy a chat modul és az intelligens diszpécser kereső tűpontos válaszokat és termékajánlásokat adhasson.') }}
                                    </p>
                                </div>
                            </div>

                            <div class="row mb-3 form-group">
                                <div class="col-sm-12">
                                    <div id="sync-table-list" style="max-height: 300px; font-size: 12px; color: #777;">
                                    </div>
                                </div>
                            </div>

                            <div class="row mb-3 form-group">
                                <div class="col-sm-12">
                                    <div id="vrcs-slider" style="background: rgba(172, 171, 180, 0.2); height: 15px; width: 100%; border-radius: 4px;"></div>
                                    <div id="sync-status-text" style="margin-top: 5px; font-weight: bold; color: #00a8c6;"></div>
                                </div>
                            </div>
                        </fieldset>
                    </div>

                    <div id="vrcs-normal-settings">

                        <ul class="nav nav-tabs">
                            <li class="active"><a href="#tab-general" data-toggle="tab">{{ tab_general }}</a></li>
                            <li><a href="#tab-chat" data-toggle="tab">{{ tab_chat_settings|default('Chat Settings') }}</a></li>
                            <li><a href="#tab-faq" data-toggle="tab">{{ tab_faq|default('FAQ') }}</a></li>
                            <li><a href="#tab-tools" data-toggle="tab">{{ tab_tools|default('Features') }}</a></li>
                            <li><a href="#tab-recovery" data-toggle="tab">{{ tab_abandoned|default('Abandoned cart') }}</a></li>
                        </ul>

                        <div class="tab-content">
                            <div class="tab-pane active" id="tab-general">


                                <div class="row mb-3 form-group">
                                    <label class="col-sm-2 control-label">{{ entry_status }}</label>
                                    <div class="col-sm-10">
                                        <select name="module_chataiwd_status" id="input-status" class="form-control">
                                            {% if module_chataiwd_status %}
                                                <option value="1" selected="selected">{{ text_enabled }}</option>
                                                <option value="0">{{ text_disabled }}</option>
                                            {% else %}
                                                <option value="1">{{ text_enabled }}</option>
                                                <option value="0" selected="selected">{{ text_disabled }}</option>
                                            {% endif %}
                                        </select>
                                    </div>
                                </div>


                                {% if module_chataiwd_registration_id %}
                                    <div class="row mb-3 form-group">
                                        <label class="col-sm-2 control-label">
                                            AI Szinkronizáció
                                        </label>
                                        <div class="col-sm-10">
                                            <button type="button" id="vrcs-force-sync-btn" class="btn btn-outline-info" onclick="triggerManualSync()">
                                                <i class="fas fa-sync-alt"></i> {{ text_syncrestart }}
                                            </button>
                                            <div class="form-text mt-2">{{ text_syncrestart_click }}</div>
                                        </div>
                                    </div>
                                {% endif %}

                                <div class="row mb-3 form-group">
                                    <label class="col-sm-2 control-label">
                                    </label>
                                    <div class="col-sm-10">
                                        {% if not module_chataiwd_registration_id %}
                                            <button type="button" onclick="openRegistrationModal()" class="btn btn-primary mt-2">
                                                <i class="fa fas fa-solid fa-user-plus"></i> {{ button_register }}
                                            </button>
                                        {% endif %}
                                    </div>
                                </div>

                                {% if module_chataiwd_registration_id %}
                                    <div style="display: none">
                                        <div class="row mb-3 form-group">
                                            <label class="col-sm-2 control-label">
                                                {{ entry_select_pack }}
                                                {# <i class="fa fas fa-info-circle ms-1" data-toggle="tooltip" data-bs-toggle="tooltip" title="{{ help_select_pack }}"></i> #}
                                            </label>
                                            <div class="col-sm-10">
                                                <select id="package-select" name="module_chataiwd_package" class="form-control">
                                                    {% for key, package in packages %}
                                                        <option value="{{ key }}" >{{ package }}</option>
                                                    {% endfor %}
                                                </select>
                                            </div>
                                        </div>

                                        {% if expiration_warning.days != -2 %}
                                            <div class="row mb-3 form-group">
                                                <label class="col-sm-2 control-label">
                                                    {{ entry_expiration_status }}
                                                </label>
                                                <div class="col-sm-10">
                                                    <button type="button" id="renew-subscription" class="btn btn-warning">
                                                        {{ expiration_warning.message }}
                                                    </button>
                                                </div>
                                            </div>
                                        {% endif %}

                                        <div class="row mb-3 form-group">
                                            <label class="col-sm-2 control-label">
                                                {{ entry_select_pack_help }}
                                            </label>

                                            <div class="col-sm-10 position-relative">
                                                <div class="content-close-package-guide">
                                                    {{ package_help }}
                                                </div>
                                            </div>
                                        </div>
                                    </div>
                                {% endif %}


                                {% if module_chataiwd_registration_id %}
                                    <div class="row mb-3 form-group vrcs-payment">
                                        <label class="col-sm-2 control-label">{{ text_chataiwd_kredit }}</label>
                                        <div class="col-sm-3">
                                            <button type="button" id="vrcs-payment-button" class="btn btn-success">
                                                <i class="fas fa fa-solid fa-credit-card"></i> {{ button_fizetes }}
                                            </button>
                                            <span>10 USD</span>
                                        </div>
                                        <div class="col-sm-3 credit-balance">
                                            {{ text_kredit_egyenleg }} <span id="credit-amount">{{ kredit}} USD</span>
                                        </div>

                                        <div class="col-sm-4 credit-balance">
                                            {% if credit_monitoring is not null %}
                                                {{ text_billing }}
                                                <div class="form-check form-switch form-switch-lg">
                                                    <input type="hidden" name="module_chataiwd_billing" value="0"/>
                                                    <input type="checkbox" name="module_chataiwd_billing" value="1" id="input-billing" class="form-check-input"{% if credit_monitoring %} checked{% endif %}/>
                                                </div>
                                            {% endif %}
                                        </div>
                                    </div>

                                    <div class="row mb-3 form-group" style="border: none; padding-top: 0;">
                                        <label class="col-sm-2 control-label"></label>
                                        <div class="col-sm-10 vrcs-payment-desc">{{ help_kredit_vrcs }}</div>
                                    </div>

                                    <!-- Fizetési modal -->
                                    <div id="payment-modal" class="modal" style="display:none;">
                                        <div class="modal-content">
                                            <span class="close-modal" onclick="closePaymentModal()">×</span>
                                            <h2>{{ button_fizetes }}</h2>
                                            <div class="mb-3">
                                                <button type="button" class="btn btn-primary" id="payment_kredit">10 USD</button>
                                            </div>
                                            <p id="payment-message"></p>
                                        </div>
                                    </div>
                                {% endif %}

                            </div>

                            <div id="tab-chat" class="tab-pane">

                                <div class="row mb-3 form-group">
                                    <label class="col-sm-2 control-label">
                                        {{ entry_prompt }}
                                        <i class="fa fas fa-info-circle ms-1" data-toggle="tooltip" data-bs-toggle="tooltip" title="{{ help_prompt }}"></i>
                                    </label>
                                    <div class="col-sm-10">
                                        <textarea name="module_chataiwd_prompt" class="form-control" placeholder="{{ help_placeholder }}">{{ module_chataiwd_prompt }}</textarea>
                                    </div>
                                </div>
                                <div class="row mb-3 form-group">
                                    <label class="col-sm-2 control-label">
                                        {{ entry_color }}
                                        <i class="fa fas fa-info-circle ms-1" data-toggle="tooltip" data-bs-toggle="tooltip" title="{{ help_color }}"></i>
                                    </label>
                                    <div class="col-sm-10">
                                        <input type="color" name="module_chataiwd_color" value="{{ module_chataiwd_color }}" class="form-control" style="width: 100px;">
                                    </div>
                                </div>

                                <div class="row mb-3 form-group">
                                    <label class="col-sm-2 control-label">
                                        {{ entry_reward_presets }}
                                        <i class="fa fas fa-info-circle ms-1" data-toggle="tooltip" data-bs-toggle="tooltip" title="{{ text_reward_help }}"></i>
                                    </label>
                                    <div class="col-sm-10">
                                        <input type="text" name="module_chataiwd_rewards" value="{{ module_chataiwd_rewards }}" class="form-control">
                                    </div>
                                </div>

                                <hr>

                                {# Nyelvi fülek navigációja #}
                                <ul class="nav nav-tabs" id="language">
                                    {% for language in languages %}
                                        <li class="{% if loop.first %}active{% endif %}">
                                            <a href="#language-{{ language.language_id }}" data-toggle="tab">
                                                <img src="language/{{ language.code }}/{{ language.code }}.png" title="{{ language.name }}"/> {{ language.name }}
                                            </a>
                                        </li>
                                    {% endfor %}
                                </ul>

                                <div class="tab-content">
                                    {% for language in languages %}
                                        <div id="language-{{ language.language_id }}" class="tab-pane {% if loop.first %}active{% endif %}">
                                            <br>
                                            {# Chat Gomb Szövege #}
                                            <div class="row mb-3 form-group">
                                                <label class="col-sm-2 control-label">
                                                    {{ entry_chat_button }}</label>
                                                <div class="col-sm-10">
                                                    <input type="text" name="chat_setting_description[{{ language.language_id }}][module_chat_button]" value="{{ module_chat_button[language.language_id] }}" class="form-control" />
                                                </div>
                                            </div>

                                            {# Welcome Message (A buborék szövege) #}
                                            <div class="row mb-3 form-group">
                                                <label class="col-sm-2 control-label">
                                                    {{ entry_welcome_message }}</label>
                                                <div class="col-sm-10">
                                                    <textarea name="chat_setting_description[{{ language.language_id }}][module_welcome_message]" class="form-control" rows="2">{{ module_welcome_message[language.language_id] }}</textarea>
                                                </div>
                                            </div>

                                            {# AI Fejléc #}
                                            <div class="row mb-3 form-group">
                                                <label class="col-sm-2 control-label">
                                                    {{ entry_ai_response_header }}</label>
                                                <div class="col-sm-10">
                                                    <input type="text" name="chat_setting_description[{{ language.language_id }}][module_ai_response_header]" value="{{ module_ai_response_header[language.language_id] }}" class="form-control" />
                                                </div>
                                            </div>

                                            {# Diszpécser Fejléc #}
                                            <div class="row mb-3 form-group">
                                                <label class="col-sm-2 control-label">
                                                    {{ entry_dispatcher_response_header }}</label>
                                                <div class="col-sm-10">
                                                    <input type="text" name="chat_setting_description[{{ language.language_id }}][module_dispatcher_response_header]" value="{{ module_dispatcher_response_header[language.language_id] }}" class="form-control" />
                                                </div>
                                            </div>

                                            <div class="row mb-3 form-group">
                                                <label class="col-sm-2 control-label">
                                                    {{ entry_ai_response_indicator }}</label>
                                                <div class="col-sm-10">
                                                    <input type="text" name="chat_setting_description[{{ language.language_id }}][module_ai_response_indicator]" value="{{ module_ai_response_indicator[language.language_id] }}" class="form-control" />
                                                </div>
                                            </div>

                                            <div class="row mb-3 form-group">
                                                <label class="col-sm-2 control-label">
                                                    {{ entry_dispatcher_response_indicator }}</label>
                                                <div class="col-sm-10">
                                                    <input type="text" name="chat_setting_description[{{ language.language_id }}][module_dispatcher_response_indicator]" value="{{ module_dispatcher_response_indicator[language.language_id] }}" class="form-control" />
                                                </div>
                                            </div>

                                        </div>
                                    {% endfor %}
                                </div>
                            </div>




                            <div id="tab-faq" class="tab-pane">
                                <br>
                                <div class="table-responsive">
                                    <table id="faq-table" class="table table-bordered table-hover">
                                        <thead>
                                        <tr>
                                            <td class="text-start" style="width: 20%;">{{ entry_faq_icon_type|default('Icon type') }}</td>
                                            <td class="text-start" style="width: 15%;">{{ entry_faq_visual|default('Icon') }}</td>
                                            <td class="text-start" style="width: 15%;">{{ entry_faq_visual|default('Image') }}</td>
                                            <td class="text-start" style="width: 25%;">{{ entry_faq_question|default('Question') }}</td>
                                            <td class="text-start" style="width: 30%;">{{ entry_faq_answer|default('Answer') }}</td>
                                            <td class="text-center" style="width: 5%;">{{ entry_status|default('Status') }}</td>
                                            <td class="text-end" style="width: 5%;"></td>
                                        </tr>
                                        </thead>
                                        <tbody>
                                        {% set faq_row = 0 %}
                                        {% for faq in module_chataiwd_faqs %}
                                            <tr id="faq-row-{{ faq_row }}" class="{% if not faq.status %}faq-disabled{% endif %}">
                                                {# Választó: Kép vagy Ikon #}
                                                <td class="text-start">
                                                    <select name="module_chataiwd_faq[{{ faq_row }}][type]" class="form-select" onchange="toggleFaqType('{{ faq_row }}', this.value);">
                                                        <option value="icon" {% if faq.type == 'icon' %}selected{% endif %}>{{ text_icon|default('Icon') }} (FontAwesome)</option>
                                                        <option value="image" {% if faq.type == 'image' %}selected{% endif %}>{{ text_image|default('Image') }}</option>
                                                    </select>
                                                </td>

                                                {# Ikon bevitel #}
                                                <td class="text-start text-start-icon" style="vertical-align: middle; position: relative">
                                                    <div class="input-group" >
                                                        <span class="input-group-text"><i class="{{ faq.icon|default('fa-solid fa-icons') }}"></i></span>
                                                        <input type="text" name="module_chataiwd_faq[{{ faq_row }}][icon]" value="{{ faq.icon }}" placeholder="fa-solid fa-truck" class="form-control"/>
                                                    </div>
                                                    <div class="arnyek {% if faq.type == 'image' %}d-arnyek{% endif %}"></div>
                                                </td>

                                                {# Képkezelő (OpenCart standard) #}
                                                <td class="text-start text-start-image" style="position: relative">
                                                    <div class="image-input">
                                                        <div class="card image" style="width: 100px;">
                                                            <img src="{{ faq.thumb }}" alt="" title="" id="thumb-image-{{ faq_row }}" data-oc-placeholder="{{ placeholder }}" class="card-img-top"/>
                                                            <input type="hidden" name="module_chataiwd_faq[{{ faq_row }}][image]" value="{{ faq.image }}" id="input-image-{{ faq_row }}"/>
                                                            <div class="card-body p-1 text-center">
                                                                <button type="button" data-oc-toggle="image" data-oc-target="#input-image-{{ faq_row }}" data-oc-thumb="#thumb-image-{{ faq_row }}" class="btn btn-primary btn-sm"><i class="fa fa-pencil"></i></button>
                                                                <button type="button" data-oc-toggle="clear" data-oc-target="#input-image-{{ faq_row }}" data-oc-thumb="#thumb-image-{{ faq_row }}" class="btn btn-warning btn-sm"><i class="fa fa-trash-o"></i></button>
                                                            </div>
                                                        </div>
                                                    </div>
                                                    <div class="arnyek {% if faq.type == 'icon' or not faq.type %}d-arnyek{% endif %}"></div>
                                                </td>

                                                {# Kérdés #}
                                                <td class="text-start">
                                                    <input type="text" name="module_chataiwd_faq[{{ faq_row }}][question]" value="{{ faq.question }}" placeholder="{{ entry_faq_question }}" class="form-control"/>
                                                </td>

                                                {# Válasz #}
                                                <td class="text-start">
                                                    <textarea name="module_chataiwd_faq[{{ faq_row }}][answer]" rows="3" placeholder="{{ entry_faq_answer }}" class="form-control">{{ faq.answer }}</textarea>
                                                </td>

                                                {# Státusz #}
                                                <td class="text-center">
                                                    <div class="form-check form-switch d-inline-block">
                                                        <input type="hidden" name="module_chataiwd_faq[{{ faq_row }}][status]" value="0"/>
                                                        <input type="checkbox" name="module_chataiwd_faq[{{ faq_row }}][status]" value="1" class="form-check-input" onchange="toggleFaqStatus({{ faq_row }}, this.checked);" {% if faq.status %}checked{% endif %}/>
                                                    </div>
                                                </td>

                                                <td class="text-end">
                                                    <button type="button" onclick="$('#faq-row-{{ faq_row }}').remove();" data-bs-toggle="tooltip" title="{{ button_remove }}" class="btn btn-danger">
                                                        <i class="fa-solid fa fa-minus-circle"></i>
                                                    </button>
                                                </td>
                                            </tr>
                                            {% set faq_row = faq_row + 1 %}
                                        {% endfor %}
                                        </tbody>
                                        <tfoot>
                                        <tr>
                                            <td colspan="5"></td>
                                            <td class="text-end">
                                                <button type="button" onclick="addFaqRow();" data-bs-toggle="tooltip" title="{{ button_add }}" class="btn btn-primary">
                                                    <i class="fa-solid fa fa-plus-circle"></i>
                                                </button>
                                            </td>
                                        </tr>
                                        </tfoot>
                                    </table>
                                </div>
                            </div>


                            <div id="tab-tools" class="tab-pane">
                                <br>
                                <div class="alert alert-info"><i class="fas fa-info-circle"></i> {{ help_tools_info|default('Here you can turn on or off the extra features that appear in the chat window..') }}</div>

                                {# 1. Diszpécser hívás (Bell) #}
                                <div class="row mb-3 form-group">
                                    <label class="col-sm-2 control-label">
                                        {{ entry_tool_bell|default('Call Dispatcher (Bell)') }}
                                        <i class="fas fa fa-info-circle ms-1" data-bs-toggle="tooltip" title="{{ help_tool_bell|default('Allows users to notify the dispatcher.') }}"></i>
                                    </label>
                                    <div class="col-sm-9">
                                        <div class="form-check form-switch form-switch-lg">
                                            <input type="hidden" name="module_chataiwd_tool_bell" value="0"/>
                                            <input type="checkbox" name="module_chataiwd_tool_bell" value="1" class="form-check-input"{% if module_chataiwd_tool_bell %} checked{% endif %}/>
                                        </div>
                                    </div>
                                </div>

                                {# 2. Mikrofon / Voice #}
                                <div class="row mb-3 form-group">
                                    <label class="col-sm-2 control-label">
                                        {{ entry_tool_voice|default('Voice Recognition') }}
                                        <i class="fas fa fa-info-circle ms-1" data-bs-toggle="tooltip" title="{{ help_tool_voice|default('Show microphone icon for voice input.') }}"></i>
                                    </label>
                                    <div class="col-sm-9">
                                        <div class="form-check form-switch form-switch-lg">
                                            <input type="hidden" name="module_chataiwd_tool_voice" value="0"/>
                                            <input type="checkbox" name="module_chataiwd_tool_voice" value="1" class="form-check-input"{% if module_chataiwd_tool_voice %} checked{% endif %}/>
                                        </div>
                                    </div>
                                </div>

                                {# 3. Képfeltöltés #}
                                <div class="row mb-3 form-group">
                                    <label class="col-sm-2 control-label">
                                        {{ entry_tool_image|default('Image Upload') }}
                                        <i class="fas fa fa-info-circle ms-1" data-bs-toggle="tooltip" title="{{ help_tool_image|default('Allows users to send images to the AI ​​or dispatcher.') }}"></i>
                                    </label>
                                    <div class="col-sm-9">
                                        <div class="form-check form-switch form-switch-lg">
                                            <input type="hidden" name="module_chataiwd_tool_image" value="0"/>
                                            <input type="checkbox" name="module_chataiwd_tool_image" value="1" class="form-check-input"{% if module_chataiwd_tool_image %} checked{% endif %}/>
                                        </div>
                                    </div>
                                </div>

                                {# 4. Emoji #}
                                <div class="row mb-3 form-group">
                                    <label class="col-sm-2 control-label">
                                        {{ entry_tool_emoji|default('Emoji Picker') }}
                                    </label>
                                    <div class="col-sm-9">
                                        <div class="form-check form-switch form-switch-lg">
                                            <input type="hidden" name="module_chataiwd_tool_emoji" value="0"/>
                                            <input type="checkbox" name="module_chataiwd_tool_emoji" value="1" class="form-check-input"{% if module_chataiwd_tool_emoji %} checked{% endif %}/>
                                        </div>
                                    </div>
                                </div>

                                {# 5. Email küldés (Levél ikon) #}
                                <div class="row mb-3 form-group">
                                    <label class="col-sm-2 control-label">
                                        {{ entry_tool_email|default('Email Contact Form') }}
                                        <i class="fas  fa fa-info-circle ms-1" data-bs-toggle="tooltip" title="{{ help_tool_email|default('Displays the mail icon for direct contact.') }}"></i>
                                    </label>
                                    <div class="col-sm-9">
                                        <div class="form-check form-switch form-switch-lg">
                                            <input type="hidden" name="module_chataiwd_tool_email" value="0"/>
                                            <input type="checkbox" name="module_chataiwd_tool_email" value="1" class="form-check-input"{% if module_chataiwd_tool_email %} checked{% endif %}/>
                                        </div>
                                    </div>
                                </div>

                                {# 6. FAQ Globális kapcsoló #}
                                <div class="row mb-3 form-group">
                                    <label class="col-sm-2 control-label">
                                        {{ entry_tool_faq|default('FAQ Module') }}
                                        <i class="fas fa fa-info-circle ms-1" data-bs-toggle="tooltip" title="{{ help_tool_faq|default('Turns the display of FAQs completely off or on.') }}"></i>
                                    </label>
                                    <div class="col-sm-9">
                                        <div class="form-check form-switch form-switch-lg">
                                            <input type="hidden" name="module_chataiwd_tool_faq" value="0"/>
                                            <input type="checkbox" name="module_chataiwd_tool_faq" value="1" class="form-check-input"{% if module_chataiwd_tool_faq %} checked{% endif %}/>
                                        </div>
                                    </div>
                                </div>

                                {# 7. WhatsApp Kapcsolat #}
                                <div class="row mb-3">
                                    <label class="col-sm-2 control-label">
                                        {{ entry_tool_whatsapp|default('WhatsApp Contact') }}
                                        <i class="fas fa fa-info-circle ms-1" data-bs-toggle="tooltip" title="{{ help_tool_whatsapp|default('Show WhatsApp direct message button.') }}"></i>
                                    </label>
                                    <div class="col-sm-9">
                                        <div class="form-check form-switch form-switch-lg">
                                            <input type="hidden" name="module_chataiwd_tool_whatsapp" value="0"/>
                                            <input type="checkbox" name="module_chataiwd_tool_whatsapp" value="1" class="form-check-input"{% if module_chataiwd_tool_whatsapp %} checked{% endif %}

                                                   onchange="
                                                       const isChecked = this.checked;
                                                       const $input = jQuery('#input-whatsapp-number');
                                                       const $container = jQuery('#whatsapp-config-container');

                                                       $input.prop('disabled', !isChecked);
                                                       $input.prop('readonly', !isChecked); // Ha nincs bepipálva, legyen readonly
                                                       $container.css('opacity', isChecked ? '1' : '0.5');
                                                   "/>


                                        </div>

                                        <div id="whatsapp-config-container" style="transition: opacity 0.3s; {% if not module_chataiwd_tool_whatsapp %}opacity: 0.5;{% endif %}">
                                            <div class="input-group">
                                                <input type="text"
                                                       name="module_chataiwd_whatsapp_number"
                                                       value="{{ module_chataiwd_whatsapp_number }}"
                                                       placeholder="{{ entry_whatsapp_placeholder|default('+36 70 123 4567') }}"
                                                       id="input-whatsapp-number"
                                                       class="form-control"
                                                       {% if not module_chataiwd_tool_whatsapp %}disabled{% endif %}/>
                                            </div>
                                            <small class="form-text text-muted">{{ help_whatsapp_number|default('Enter the phone number in international format.') }}</small>
                                        </div>
                                    </div>
                                </div>
                            </div>

                            <div class="tab-pane" id="tab-recovery">
                                <br>
                                <div class="alert alert-info">
                                    <i class="fas fa-info-circle"></i> {{ help_recovery_info|default('Set up a maximum of 5 reminder emails. Empty rows will not be sent.') }}
                                </div>

                                <div class="table-responsive">
                                    <table id="recovery-table" class="table table-bordered table-hover">
                                        <thead>
                                        <tr>
                                            <td class="text-center" style="width: 50px;">#</td>
                                            <td class="text-start" style="width: 250px;">{{ entry_recovery_delay|default('Delay') }}</td>
                                            <td class="text-start">{{ entry_recovery_subject|default('Email subject (Empty = not sent)') }}</td>
                                            <td class="text-start">{{ entry_recovery_content|default('Message content') }}</td>
                                            <td class="text-center" style="width: 100px;">{{ entry_status }}</td>
                                        </tr>
                                        </thead>
                                        <tbody>
                                        {% for i in 0..4 %}
                                            <tr>
                                                <td class="text-center" style="vertical-align: middle;"><strong>{{ i + 1 }}.</strong></td>
                                                <td class="text-start">
                                                    <div class="input-group">
                                                        <input type="number" name="module_chataiwd_recovery[{{ i }}][value]" value="{{ module_chataiwd_recovery[i].value }}" class="form-control" min="1" placeholder="Idő..." />
                                                        <select name="module_chataiwd_recovery[{{ i }}][unit]" class="form-select" style="max-width: 100px;">
                                                            <option value="hours" {% if module_chataiwd_recovery[i].unit == 'hours' %}selected{% endif %}>{{ text_hours|default('Hour') }}</option>
                                                            <option value="days" {% if module_chataiwd_recovery[i].unit == 'days' %}selected{% endif %}>{{ text_days|default('Day') }}</option>
                                                        </select>
                                                    </div>
                                                </td>
                                                <td class="text-start">
                                                    <input type="text" name="module_chataiwd_recovery[{{ i }}][subject]" value="{{ module_chataiwd_recovery[i].subject }}"
                                                           class="form-control" placeholder="{{ text_subject|default('E.g.: Did you forget something?') }}" />
                                                </td>
                                                <td class="text-start">
                                                    <textarea name="module_chataiwd_recovery[{{ i }}][content]"
                                                              class="form-control" rows="2" placeholder="{{ text_content_placeholder|default('Message...') }}" style="font-size: 0.9rem;">{{ module_chataiwd_recovery[i].content }}</textarea>
                                                </td>

                                                <td class="text-center">
                                                    <div class="form-check form-switch d-inline-block">
                                                        <input type="hidden" name="module_chataiwd_recovery[{{ i }}][status]" value="0"/>
                                                        <input type="checkbox" name="module_chataiwd_recovery[{{ i }}][status]" value="1" class="form-check-input" {% if module_chataiwd_recovery[i].status %}checked{% endif %}/>
                                                    </div>
                                                </td>
                                            </tr>
                                        {% endfor %}
                                        </tbody>
                                    </table>
                                </div>
                            </div>
                        </div>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>



<!-- Message popup modal -->
{% if message is defined and message is not empty %}
    <div id="message-modal" class="modal" style="display: block;">
        <div class="modal-content" style="position: fixed; top: 15%; left: 50%; transform: translate(-50%, -50%); background-color: #fff; padding: 20px; border: 1px solid #ddd; border-radius: 8px; width: 80%; max-width: 400px; text-align: center; z-index: 1002;">
            <span class="close-modal" onclick="$('#message-modal').remove();">×</span>
            <p>{{ message|raw }}</p>
        </div>
    </div>
{% endif %}

<!-- Regisztrációs modal -->
<div id="registration-modal" class="modal" style="display:none;">
    <div class="modal-content">
        <span class="close-modal" onclick="closeRegistrationModal()">×</span>
        <h2>Registration</h2>
        <form id="registration-form" onsubmit="return false;" novalidate>
            <div>
                <label for="user-email">Email address *</label>
                <input
                        type="email"
                        id="user-email"
                        name="user-email"
                        required
                        placeholder="Enter your email address."
                        title="Please enter a valid email address (e.g., user@domain.com)."
                >
            </div>
            <button type="button" class="btn btn-primary">{{ text_registratin|default('Registration') }}</button>
        </form>
        <p id="registration-message"></p>
    </div>
</div>

<!-- Duration modal -->
<div id="duration-modal" class="modal" style="display:none;">
    <div class="modal-content">
        <span class="close-modal" onclick="closeDurationModal()">×</span>
        <label class="control-label">{{ entry_duration }}</label>
        <div class="col-sm-10">
            <div class="form-check">
                <input type="radio" name="duration" id="duration-3" value="3" class="form-check-input">
                <label for="duration-3" class="form-check-label">{{ text_duration_3 }}</label>
            </div>
            <div class="form-check">
                <input type="radio" name="duration" id="duration-6" value="6" class="form-check-input">
                <label for="duration-6" class="form-check-label">{{ text_duration_6 }}</label>
            </div>
            <div class="form-check">
                <input type="radio" name="duration" id="duration-9" value="9" class="form-check-input">
                <label for="duration-9" class="form-check-label">{{ text_duration_9 }}</label>
            </div>
            <div class="form-check">
                <input type="radio" name="duration" id="duration-12" value="12" class="form-check-input">
                <label for="duration-12" class="form-check-label">{{ text_duration_12 }}</label>
            </div>
        </div>
    </div>
</div>


